    "D4_terminology":       { "pass": 8.5, "excellent": 9.5 },
    "D5_stale_refs":        { "pass": 10.0, "excellent": 10.0 },
    "D6_numbers":           { "pass": 10.0, "excellent": 10.0 },
    "D7_editorial":         { "pass": 7.5, "excellent": 9.0 },
    "D8_audit_resilience":  { "pass": 8.5, "excellent": 9.5 }
  },
  "code_quality_gates": {
    "C1_functionality":     { "pass": 8.0, "excellent": 9.5 },
    "C2_architecture":      { "pass": 9.0, "excellent": 9.5 },
    "C3_security":          { "pass": 9.0, "excellent": 10.0 },
    "C4_code_quality":      { "pass": 7.5, "excellent": 9.0 },
    "C5_doc_consistency":   { "pass": 8.5, "excellent": 9.5 },
    "C6_operability":       { "pass": 7.5, "excellent": 9.0 }
  },
  "escalation": {
    "doc_soft_escalation_after": 10,
    "doc_hard_escalation_after": 20,
    "code_soft_escalation_after": 5,
    "code_hard_escalation_after": 10,
    "cost_alert_usd": 15,
    "cost_stop_usd": 30,
    "time_alert_hours": 48,
    "time_stop_hours": 72,
    "stagnation_trigger": 3
  },
  "architecture_state": {
    "hard_gates_total": 22,
    "hard_gates_core_sprint0": 14,
    "soft_gates_total": 22,
